        <zone h='7250' id='9' name='COHORT RETENTION ANALYSIS' pane-specification-id='0' param='[federated.0yhvhsq0zbcip315j3wke0ygauby].[:Measure Names]' type-v2='color' w='19100' x='49200' y='1000' />
        <zone h='19750' id='10' type-v2='text' w='23500' x='3600' y='40625'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Revenue shows a strong upward trend from 2016 to 2018, indicating growing customer adoption and increased transaction volume over time.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Action:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Focus on identifying key drivers (e.g., product categories or customer segments) contributing to growth and double down on those areas.</run>
          </formatted-text>
        </zone>
        <zone h='19750' id='11' type-v2='text' w='23500' x='34600' y='39875'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Revenue shows a strong upward trend from 2016 to 2018, indicating growing customer adoption and increased transaction volume over time.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Action:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Focus on identifying key drivers (e.g., product categories or customer segments) contributing to growth and double down on those areas.</run>
          </formatted-text>
        </zone>
        <zone h='33250' id='12' name='Funnel analysis' w='33300' x='65100' y='32250' />
        <zone h='22750' id='13' type-v2='text' w='20400' x='20100' y='76250'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>A large majority of users are one-time buyers, while repeat customers represent a small but critical portion of the user base.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'> Action:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Prioritize converting one-time buyers into repeat users through targeted campaigns and improved onboarding experience. </run>
          </formatted-text>
        </zone>
        <zone h='13750' id='14' type-v2='text' w='33300' x='68300' y='83250'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>A few product categories contribute disproportionately to total revenue, indicating strong product-market fit in those segments.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>ction:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Invest more in high-performing categories (inventory, ads, recommendations) and optimize underperforming ones.</run>
