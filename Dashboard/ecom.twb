      <aliases enabled='yes' />
      <column caption='Repeat customer ' datatype='string' name='[Calculation_1696532492816384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [customer_id] : COUNT([order_id]) } &gt; 1 THEN &quot;Repeat&quot;&#10;ELSE &quot;One-time&quot;&#10;END' />
      </column>
      <column caption='Cohort Month' datatype='datetime' name='[Calculation_1696532495409154]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, { FIXED [customer_id] : MIN([order_date]) })' />
      </column>
      <column caption='Cohort Index' datatype='integer' name='[Calculation_1696532495929347]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;,&#10;{ FIXED [customer_id] : MIN([order_date]) },&#10;[order_date])' />
      </column>
      <column caption='Order Count' datatype='integer' name='[Calculation_1696532496048132]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : COUNT([order_id]) }' />
      </column>
      <column caption='Funnel Categories' datatype='string' name='[Calculation_1696532496482311]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1696532496048132] = 1 THEN &quot;1 Purchase&quot;&#10;ELSEIF [Calculation_1696532496048132] = 2 THEN &quot;2 Purchases&quot;&#10;ELSE &quot;3+ Purchases&quot;&#10;END' />
      </column>
      <column caption='North Star Metric' datatype='real' name='[Calculation_1696532496605192]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNTD(&#10;IF { FIXED [customer_id] : COUNT([order_id]) } &gt; 1 &#10;THEN [customer_id] END&#10;)&#10;/&#10;COUNTD([customer_id])' />
      </column>
      <column caption='Average Order Value (AOV)' datatype='real' name='[Calculation_1696532496711689]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value]) / COUNTD([order_id])' />
      </column>
      <column caption='. Daily Active Users (DAU)' datatype='integer' name='[Calculation_1696532496789514]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Monthly Active Users' datatype='integer' name='[Calculation_1696532496916491]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Total Spend per Customer' datatype='real' name='[Calculation_1696532501016589]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : SUM([payment_value]) }' />
      </column>
      <column caption='Order Count per Customer' datatype='integer' name='[Calculation_1696532501098510]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : COUNTD([order_id]) }' />
      </column>
      <column caption='Customer Segment' datatype='string' name='[Calculation_1696532501196815]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1696532501098510] = 1 THEN &quot;One-time&quot;&#10;ELSEIF [Calculation_1696532501098510] = 2 THEN &quot;Repeat&quot;&#10;ELSE &quot;Loyal&quot;&#10;END' />
      </column>
